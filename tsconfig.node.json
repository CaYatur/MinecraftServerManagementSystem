{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "lib": ["ES2023"],
    "types": ["node"],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    },
    "outDir": "out-tsc/node"
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "electron.vite.config.ts"
  ]
}
